# =============================================================================
# .gitignore — ObsidianDB
# Стратегия: Core (движок) под version control, Data (контент) — отдельно
# См. _tech/reports/core-vs-data-separation-analysis.md
# =============================================================================

# ── BUILD ARTIFACTS (генерируются, не коммитить) ──────────────────────────
.venv/
graphify-out/
__pycache__/
*.pyc

# ── DATA: База знаний (создаётся агентами, не версионировать) ─────────────
wiki/

# ── DATA: Исходные спецификации (бинарные PDF, 181 MB) ───────────────────
# Исключены из git — должны быть доступны локально для агентов
Specifications/
# НО: .category-map.md — single source of truth series→topic (Core!)
!Specifications/.category-map.md
!Specifications/!INCOMING/.gitkeep
!Specifications/!double/.gitkeep

# ── DATA: Извлечённые эталонные тексты (восстанавливаемые) ────────────────
specs-extracted/
# НО: INDEX.md — карта форматов (Core!)
!specs-extracted/INDEX.md

# ── DATA: Пользовательские заметки и клиппинги ────────────────────────────
notes/
Clippings/

# ── DATA: Сгенерированные отчёты ──────────────────────────────────────────
outputs/

# ── CACHE: speckit metadata + backups ────────────────────────────────────
_backups/
.speckit/

# ── Obsidian: волатильные/бинарные файлы ─────────────────────────────────
.obsidian/workspace.json
.obsidian/plugins/
.trash/

# ── Claude Code: сессионные данные ───────────────────────────────────────
.claudian/

# ── Temp и inbox ──────────────────────────────────────────────────────────
raw/

# ── Claude Code: runtime lock files ───────────────────────────────────
.claude/scheduled_tasks.lock
